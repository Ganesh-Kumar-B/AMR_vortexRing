#!/bin/sh

cd "${0%/*}" || exit
. ${WM_PROJECT_DIR:?}/bin/tools/RunFunctions

# Build custom vortex-ring initialization utility

(
cd ../utilities/createVortexRing || exit 1
wmake
)

# Build custom AMR solver

(
cd ../solvers/pimpleFoamVortRefine || exit 1
wmake
)

# Convert mesh from I-DEAS UNV format

ideasUnvToFoam vortex_ring.unv

# Create initial time directory

rm -rf 0
cp -r 0.orig 0

# Initialize vortex-ring velocity and vorticity fields

createVortexRing

# Decompose domain for parallel execution

decomposePar -force

# Run simulation in parallel

mpirun --oversubscribe -np 6 pimpleFoamVortRefine -parallel
